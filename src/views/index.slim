.panel
  h2 Runtime Health
  .metrics-grid
    .metric
      .label Requests RPS
      .value#metric-requests 0
    .metric
      .label Errors RPS
      .value#metric-errors 0
    .metric
      .label Cancels RPS
      .value#metric-cancels 0
    .metric
      .label Reconstruct Success
      .value#metric-success 0%

.panel
  h2 NATS Runtime
  details.disclosure
    summary
      | Connection / Transport details
      span.nats-mode-pill#nats-mode api-only
    .nats-grid
      .nats-block
        .k Connected
        .v#nats-connected -
      .nats-block
        .k Ping / Pong
        .v#nats-ping-counters -
      .nats-block
        .k Server
        .v#nats-server -
      .nats-block
        .k Disconnected
        .v#nats-disconnected -
      .nats-block
        .k Last Error
        .v#nats-last-error -
      .nats-block
        .k Stream
        .v#nats-stream -
      .nats-block
        .k Consumer
        .v#nats-consumer -
      .nats-block
        .k Stream Messages
        .v#nats-stream-messages -
      .nats-block
        .k Consumer Pending
        .v#nats-consumer-pending -
    pre.nats-raw
      code#nats-raw.language-json

.panel
  h2 Load and Errors (60s)
  svg#load-chart
  .legend Requests and errors from `/observability/metrics`
  .table-wrap#chart-fallback style="display:none"
    table
      thead
        tr
          th Time
          th Requests
          th Errors
      tbody#chart-fallback-body

.panel
  h2 Flow Explorer
  .controls
    .control
      label for="request-id" Request ID
      input#request-id[type="text" placeholder="req-..."]
    .control
      label for="subject-filter" Subject contains
      input#subject-filter[type="text" placeholder="to.proxy..."]
    .control
      label for="event-type" Event type
      select#event-type
        option[value=""] all
        option[value="request_published"] request_published
        option[value="response_start"] response_start
        option[value="response_chunk"] response_chunk
        option[value="response_error"] response_error
        option[value="response_end"] response_end
        option[value="session_established"] session_established
        option[value="session_close"] session_close
        option[value="cancel_published"] cancel_published
        option[value="cancel_observed"] cancel_observed
    .control
      label for="outcome-filter" Outcome
      select#outcome-filter
        option[value=""] all
        option[value="success"] success
        option[value="error"] error
        option[value="timeout"] timeout
        option[value="canceled"] canceled
        option[value="in_progress"] in_progress
    .control
      label for="limit" Limit
      input#limit[type="number" value="100" min="1" max="200"]
    button#refresh-cases.btn.primary[type="button"] Refresh
  .legend#cases-summary Select a row below to open Case Timeline (auto-refreshes with the list)
  .table-wrap
    table
      thead
        tr
          th Status
          th Request ID
          th Method
          th Path
          th Subject
          th Events
          th Chunks
          th Duration
          th Last Event
      tbody#cases-table

.panel#case-timeline-panel hidden="hidden"
  h2 Case Timeline
  .legend#case-selected
  #stream-reconstruct hidden="hidden"
    .stream-reconstruct-header
      span#stream-reconstruct-label
      button#stream-reconstruct-toggle.btn[type="button"] Collapse
    .stream-reconstruct-body
      #stream-fields
  .table-wrap
    table
      thead
        tr
          th.event-meta-col EVENT
          th.nats-payload-col NATS BODY
      tbody#case-events-table

javascript:
  (function() {
    function q(id) { return document.getElementById(id); }
    function esc(v) { return String(v == null ? '' : v).replace(/[&<>"]/g, function(c) { return ({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;'})[c]; }); }
    function fmt(v, n) { var x = Number(v || 0); return Number.isFinite(x) ? x.toFixed(n == null ? 2 : n) : '0.00'; }

    var chartHistory = [];
    var chartMax = 60;
    var chartSvg = null;
    var selectedRequestId = null;

    function api(path) {
      return fetch(path).then(function(res) {
        if (!res.ok) throw new Error(res.status + ' ' + res.statusText);
        return res.json();
      });
    }

    function renderMetrics(metrics) {
      q('metric-requests').textContent = fmt(metrics.rates && metrics.rates.requests_rps, 2);
      q('metric-errors').textContent = fmt(metrics.rates && metrics.rates.errors_rps, 2);
      q('metric-cancels').textContent = fmt(metrics.rates && metrics.rates.cancels_rps, 2);
      q('metric-success').textContent = fmt((metrics.reconstruction_quality && metrics.reconstruction_quality.success_ratio || 0) * 100, 1) + '%';
    }

    function setText(id, value) {
      var el = q(id);
      if (!el) return;
      el.textContent = value == null || value === '' ? '-' : String(value);
    }

    function parseMaybeJson(value) {
      if (value == null) return null;
      if (typeof value === 'object') return value;
      var s = String(value).trim();
      if (!s || (s[0] !== '{' && s[0] !== '[')) return null;
      try { return JSON.parse(s); } catch (_) { return null; }
    }

    function deepParseNestedJson(value, depth) {
      if (depth == null) depth = 0;
      if (depth > 8) return value;
      if (Array.isArray(value)) return value.map(function(item) { return deepParseNestedJson(item, depth + 1); });
      if (value && typeof value === 'object') {
        var out = {};
        Object.keys(value).forEach(function(k) { out[k] = deepParseNestedJson(value[k], depth + 1); });
        return out;
      }
      if (typeof value !== 'string') return value;
      var parsed = parseMaybeJson(value);
      return parsed == null ? value : deepParseNestedJson(parsed, depth + 1);
    }

    function highlightJson(raw) {
      if (window.Prism && window.Prism.languages && window.Prism.languages.json) {
        return window.Prism.highlight(raw, window.Prism.languages.json, 'json');
      }
      return esc(raw);
    }

    var PAYLOAD_COLLAPSE_THRESHOLD = 20;
    var PAYLOAD_HEAD_LINES = 10;
    var PAYLOAD_TAIL_LINES = 10;

    function renderPayloadCell(value) {
      var parsed = parseMaybeJson(value);
      if (!parsed) {
        var plain = esc(value == null ? '' : value);
        return '<pre class="nats-payload-pre"><code class="language-json">' + plain + '</code></pre>';
      }
      var normalized = deepParseNestedJson(parsed, 0);
      var raw = JSON.stringify(normalized, null, 2);
      var lines = raw.split('\n');
      if (lines.length <= PAYLOAD_COLLAPSE_THRESHOLD) {
        return '<pre class="nats-payload-pre"><code class="language-json">' + highlightJson(raw) + '</code></pre>';
      }
      var headRaw = lines.slice(0, PAYLOAD_HEAD_LINES).join('\n');
      var tailRaw = lines.slice(lines.length - PAYLOAD_TAIL_LINES).join('\n');
      var hiddenCount = lines.length - PAYLOAD_HEAD_LINES - PAYLOAD_TAIL_LINES;
      var fullHtml = highlightJson(raw);
      var headHtml = highlightJson(headRaw);
      var tailHtml = highlightJson(tailRaw);
      return '<div class="payload-wrap">' +
        '<pre class="nats-payload-pre payload-head">' +
          '<code class="language-json">' + headHtml + '</code>' +
        '</pre>' +
        '<button class="payload-expand-btn" type="button">Show all ' + lines.length + ' lines (' + hiddenCount + ' hidden)</button>' +
        '<pre class="nats-payload-pre payload-tail">' +
          '<code class="language-json">' + tailHtml + '</code>' +
        '</pre>' +
        '<pre class="nats-payload-pre payload-full" style="display:none">' +
          '<code class="language-json">' + fullHtml + '</code>' +
        '</pre>' +
      '</div>';
    }

    function renderNatsState(payload) {
      var connection = payload.connection || {};
      var stats = payload.stats || {};
      var modeDetails = payload.mode_details || {};
      var serverInfo = connection.server_info || {};
      var serverLabel = serverInfo.server_name || serverInfo.server_id || serverInfo.version || '-';
      q('service-id').textContent = 'service_id: ' + (payload.service_id || '-');
      q('backend-mode').textContent = 'backend: ' + (payload.backend || '-') + ' / role: ' + (payload.role || '-');

      var natsModeLabel = modeDetails.jetstream_available === true ? 'jetstream' : 'core/api';
      setText('nats-mode', natsModeLabel);
      setText('nats-connected', connection.connected);
      setText('nats-ping-counters', (stats.sent_pings || 0) + ' / ' + (stats.received_pongs || 0));
      setText('nats-server', serverLabel);
      setText('nats-disconnected', connection.disconnected);
      setText('nats-last-error', connection.last_error);

      setText('nats-stream', modeDetails.stream);
      setText('nats-consumer', modeDetails.consumer);
      setText('nats-stream-messages', modeDetails.stream_messages);
      setText('nats-consumer-pending', modeDetails.consumer_num_pending);

      renderNatsRaw(payload);
    }

    function renderNatsRaw(payload) {
      var code = q('nats-raw');
      if (!code) return;
      var raw = JSON.stringify(payload, null, 2);
      if (window.Prism && window.Prism.languages && window.Prism.languages.json) {
        code.innerHTML = window.Prism.highlight(raw, window.Prism.languages.json, 'json');
      } else {
        code.textContent = raw;
      }
    }

    function appendChartPoint(metrics) {
      chartHistory.push({
        ts: new Date(metrics.ts || Date.now()),
        requests: Number(metrics.rates && metrics.rates.requests_rps || 0),
        errors: Number(metrics.rates && metrics.rates.errors_rps || 0)
      });
      if (chartHistory.length > chartMax) chartHistory.shift();
      renderLineChart();
    }

    function renderLineChart() {
      if (!chartSvg || chartHistory.length === 0) return;
      if (!window.d3) { renderChartFallback(); return; }
      var d3 = window.d3;
      var width = chartSvg.clientWidth || 600;
      var height = chartSvg.clientHeight || 260;
      var margin = { top: 12, right: 24, bottom: 22, left: 34 };
      var innerW = width - margin.left - margin.right;
      var innerH = height - margin.top - margin.bottom;
      var svg = d3.select(chartSvg);
      svg.selectAll('*').remove();

      var x = d3.scaleLinear().domain([0, Math.max(chartHistory.length - 1, 1)]).range([0, innerW]);
      var yMax = d3.max(chartHistory, function(d) { return Math.max(d.requests, d.errors); }) || 1;
      var y = d3.scaleLinear().domain([0, yMax * 1.2]).range([innerH, 0]);

      var g = svg.append('g').attr('transform', 'translate(' + margin.left + ',' + margin.top + ')');
      g.append('g').attr('transform', 'translate(0,' + innerH + ')').call(d3.axisBottom(x).ticks(5));
      g.append('g').call(d3.axisLeft(y).ticks(5));

      var reqLine = d3.line().x(function(_, i) { return x(i); }).y(function(d) { return y(d.requests); });
      var errLine = d3.line().x(function(_, i) { return x(i); }).y(function(d) { return y(d.errors); });

      g.append('path').datum(chartHistory).attr('fill', 'none').attr('stroke', '#67c784').attr('stroke-width', 2).attr('d', reqLine);
      g.append('path').datum(chartHistory).attr('fill', 'none').attr('stroke', '#f05252').attr('stroke-width', 2).attr('d', errLine);
      var fallbackWrap = q('chart-fallback');
      if (fallbackWrap) fallbackWrap.style.display = 'none';
    }

    function renderChartFallback() {
      var wrap = q('chart-fallback');
      var body = q('chart-fallback-body');
      if (!wrap || !body) return;
      wrap.style.display = 'block';
      var recent = chartHistory.slice(-12);
      body.innerHTML = recent.map(function(p) {
        return '<tr><td>' + esc(p.ts.toISOString()) + '</td><td>' + esc(fmt(p.requests, 2)) + '</td><td>' + esc(fmt(p.errors, 2)) + '</td></tr>';
      }).join('');
    }

    function statusClass(status) {
      if (status === 'completed') return 'ok';
      if (status === 'failed' || status === 'timed_out') return 'err';
      if (status === 'canceled') return 'warn';
      return 'info';
    }

    function normalizeSubject(subject) {
      var s = String(subject == null ? '' : subject);
      return s.replace(/^(.+\.[^.]+)\.[A-Za-z0-9_-]{16,}$/i, '$1');
    }

    function renderCasesTable(payload) {
      var rows = payload.cases || [];
      var tbody = q('cases-table');
      q('cases-summary').textContent = 'cases=' + rows.length + ', state=' + ((payload.feed_health && payload.feed_health.state) || 'unknown');
      if (rows.length === 0) {
        tbody.innerHTML = '<tr><td colspan="9">No flow cases found for filters.</td></tr>';
        return;
      }
      tbody.innerHTML = rows.map(function(row) {
        var activeClass = row.request_id === selectedRequestId ? ' class="active-case"' : '';
        return '<tr data-request-id="' + esc(row.request_id || '') + '"' + activeClass + '>' +
          '<td><span class="pill ' + statusClass(row.status) + '">' + esc(row.status || '') + '</span></td>' +
          '<td class="mono">' + esc(row.request_id || '') + '</td>' +
          '<td>' + esc(row.method || '-') + '</td>' +
          '<td class="mono">' + esc(row.path || '-') + '</td>' +
          '<td class="mono">' + esc(row.subject || '') + '</td>' +
          '<td>' + esc(row.events_total || 0) + '</td>' +
          '<td>' + esc(row.chunks_total || 0) + '</td>' +
          '<td>' + esc(row.duration_ms == null ? '-' : row.duration_ms) + '</td>' +
          '<td>' + esc(row.last_event_at || '') + '</td>' +
        '</tr>';
      }).join('');
    }

    function caseTimelineRowHtml(row) {
      var typeClass = row.type && row.type.indexOf('error') >= 0 ? 'err' : (row.type && row.type.indexOf('cancel') >= 0 ? 'warn' : 'ok');
      var eid = row.event_id != null ? String(row.event_id) : '';
      var metaHtml =
        '<span class="event-ts">' + esc(row.ts || '') + '</span>' +
        '<span class="pill ' + typeClass + '">' + esc(row.type || '') + '</span>' +
        '<span class="event-subj mono">' + esc(normalizeSubject(row.subject || '')) + '</span>';
      return '<tr data-event-id="' + esc(eid) + '">' +
        '<td class="event-meta-cell">' + metaHtml + '</td>' +
        '<td class="nats-payload">' + renderPayloadCell(row.nats_payload) + '</td>' +
      '</tr>';
    }

    function parseChunkJsonLines(chunkBody, contentType) {
      var ct = (contentType || '').toLowerCase();
      var jsonLines = [];
      var lines = chunkBody.split('\n');
      if (ct.indexOf('text/event-stream') >= 0) {
        for (var i = 0; i < lines.length; i++) {
          var line = lines[i];
          if (line.indexOf('data:') !== 0) continue;
          var data = line.slice(5).trim();
          if (data && data !== '[DONE]') jsonLines.push(data);
        }
      } else {
        for (var i = 0; i < lines.length; i++) {
          var line = lines[i].trim();
          if (line) jsonLines.push(line);
        }
      }
      var result = [];
      for (var i = 0; i < jsonLines.length; i++) {
        try { result.push(JSON.parse(jsonLines[i])); } catch (_) {}
      }
      return result;
    }

    function collectLeafPaths(obj, prefix, out) {
      if (obj === null || obj === undefined) return;
      var t = typeof obj;
      if (t === 'string' || t === 'number' || t === 'boolean') {
        out[prefix] = t;
        return;
      }
      if (Array.isArray(obj)) {
        for (var i = 0; i < obj.length; i++) collectLeafPaths(obj[i], prefix + '[' + i + ']', out);
        return;
      }
      if (t === 'object') {
        var keys = Object.keys(obj);
        for (var k = 0; k < keys.length; k++) {
          collectLeafPaths(obj[keys[k]], prefix ? prefix + '.' + keys[k] : keys[k], out);
        }
      }
    }

    function getByPath(obj, path) {
      var parts = path.replace(/\[(\d+)\]/g, '.$1').split('.');
      var cur = obj;
      for (var i = 0; i < parts.length; i++) {
        if (cur == null) return undefined;
        cur = cur[parts[i]];
      }
      return cur;
    }

    var ISO8601_RE = /^\d{4}-\d{2}-\d{2}T[\d:.]+Z?$/;

    function classifyPaths(allObjs) {
      var pathTypes = {};
      var PROBE = Math.min(allObjs.length, 50);
      for (var i = 0; i < PROBE; i++) {
        collectLeafPaths(allObjs[i], '', pathTypes);
      }

      var deltaStr = [];
      var staticStr = [];
      var staticOther = [];

      var paths = Object.keys(pathTypes);
      for (var p = 0; p < paths.length; p++) {
        var path = paths[p];
        if (pathTypes[path] !== 'string') {
          staticOther.push(path);
          continue;
        }

        var firstNonEmpty = null;
        var distinctNonEmpty = 0;
        var hasNonEmpty = false;
        var isTimestamp = false;

        for (var i = 0; i < allObjs.length; i++) {
          var v = getByPath(allObjs[i], path);
          if (typeof v !== 'string' || v === '') continue;
          if (!hasNonEmpty) {
            firstNonEmpty = v;
            hasNonEmpty = true;
            if (ISO8601_RE.test(v)) { isTimestamp = true; break; }
            distinctNonEmpty = 1;
          } else if (v !== firstNonEmpty) {
            distinctNonEmpty++;
            if (distinctNonEmpty >= 2) break;
          }
        }

        if (isTimestamp) continue;
        if (!hasNonEmpty) continue;

        if (distinctNonEmpty >= 2) deltaStr.push(path);
        else staticStr.push(path);
      }
      return { deltaStr: deltaStr, staticStr: staticStr, staticOther: staticOther };
    }

    function reconstructStream(events) {
      var panel = q('stream-reconstruct');
      if (!panel) return;

      var startEvent = null;
      var chunkEvents = [];
      var isFinished = false;

      for (var i = 0; i < events.length; i++) {
        var ev = events[i];
        if (ev.type === 'response_start') { startEvent = ev; }
        else if (ev.type === 'response_chunk') { chunkEvents.push(ev); }
        else if (ev.type === 'response_end') { isFinished = true; }
      }

      if (!startEvent || chunkEvents.length === 0) {
        panel.setAttribute('hidden', 'hidden');
        return;
      }

      var parsedStart = parseMaybeJson(startEvent.nats_payload);
      var contentType = (parsedStart && parsedStart.content_type) || '';

      if (!contentType || (contentType.indexOf('ndjson') < 0 && contentType.indexOf('event-stream') < 0)) {
        panel.setAttribute('hidden', 'hidden');
        return;
      }

      var allObjs = [];
      for (var i = 0; i < chunkEvents.length; i++) {
        var parsedChunk = parseMaybeJson(chunkEvents[i].nats_payload);
        if (!parsedChunk || !parsedChunk.body) continue;
        var objs = parseChunkJsonLines(parsedChunk.body, contentType);
        for (var j = 0; j < objs.length; j++) allObjs.push(objs[j]);
      }

      if (allObjs.length === 0) { panel.setAttribute('hidden', 'hidden'); return; }

      var classified = classifyPaths(allObjs);

      var deltaAcc = {};
      for (var p = 0; p < classified.deltaStr.length; p++) deltaAcc[classified.deltaStr[p]] = '';

      var staticUniq = {};
      var keys = classified.staticStr.concat(classified.staticOther);
      for (var p = 0; p < keys.length; p++) staticUniq[keys[p]] = new Set();

      for (var i = 0; i < allObjs.length; i++) {
        for (var p = 0; p < classified.deltaStr.length; p++) {
          var v = getByPath(allObjs[i], classified.deltaStr[p]);
          if (typeof v === 'string') deltaAcc[classified.deltaStr[p]] += v;
        }
        for (var p = 0; p < keys.length; p++) {
          var v = getByPath(allObjs[i], keys[p]);
          if (v !== undefined && v !== null) {
            var s = String(v);
            var bucket = staticUniq[keys[p]];
            if (bucket instanceof Set) { bucket.add(s); }
            else if (bucket.indexOf(s) < 0) { bucket.push(s); }
          }
        }
      }

      var html = '';

      for (var p = 0; p < classified.deltaStr.length; p++) {
        var path = classified.deltaStr[p];
        var text = deltaAcc[path];
        if (!text.trim()) continue;
        html += '<div class="stream-field">' +
          '<div class="stream-field-key">' + esc(path) + ' <span class="stream-field-badge stream-delta">stream</span></div>' +
          '<pre class="stream-pre" data-path="' + esc(path) + '">' + esc(text) + '</pre>' +
        '</div>';
      }

      for (var p = 0; p < keys.length; p++) {
        var path = keys[p];
        var bucket = staticUniq[path];
        var vals = bucket instanceof Set ? Array.from(bucket) : bucket;
        if (!vals.length) continue;
        var display = vals.join(' | ');
        html += '<div class="stream-field stream-field-static">' +
          '<div class="stream-field-key">' + esc(path) + ' <span class="stream-field-badge stream-static">static</span></div>' +
          '<div class="stream-field-static-val">' + esc(display) + '</div>' +
        '</div>';
      }

      if (!html) { panel.setAttribute('hidden', 'hidden'); return; }

      var fieldsEl = q('stream-fields');

      var savedScroll = {};
      var oldPres = fieldsEl.querySelectorAll('pre[data-path]');
      for (var i = 0; i < oldPres.length; i++) {
        var key = oldPres[i].getAttribute('data-path');
        if (oldPres[i].scrollTop > 0) savedScroll[key] = oldPres[i].scrollTop;
      }

      fieldsEl.innerHTML = html;

      if (Object.keys(savedScroll).length) {
        var newPres = fieldsEl.querySelectorAll('pre[data-path]');
        for (var i = 0; i < newPres.length; i++) {
          var key = newPres[i].getAttribute('data-path');
          if (savedScroll[key] != null) newPres[i].scrollTop = savedScroll[key];
        }
      }

      var label = q('stream-reconstruct-label');
      if (label) label.textContent = (isFinished ? 'Reconstructed' : 'Streaming\u2026') +
        ' \u00b7 ' + chunkEvents.length + ' chunks \u00b7 ' + contentType;

      panel.removeAttribute('hidden');
    }

    function renderCaseTimeline(payload, requestId) {
      var rows = payload.events || [];
      var tbody = q('case-events-table');
      q('case-selected').textContent = 'request_id=' + requestId + ', events=' + rows.length;

      reconstructStream(rows);

      if (rows.length === 0) {
        tbody.innerHTML = '<tr><td colspan="2">No events for selected request.</td></tr>';
        return;
      }

      var dataRows = tbody.querySelectorAll('tr[data-event-id]');
      var oldIds = Array.prototype.map.call(dataRows, function(tr) { return tr.getAttribute('data-event-id') || ''; });
      var newIds = rows.map(function(r) { return r.event_id != null ? String(r.event_id) : ''; });

      if (oldIds.length === 0) {
        tbody.innerHTML = rows.map(caseTimelineRowHtml).join('');
        return;
      }

      var prefix = 0;
      while (prefix < oldIds.length && prefix < newIds.length && oldIds[prefix] === newIds[prefix]) prefix++;

      if (prefix === oldIds.length && prefix === newIds.length) return;

      if (prefix === oldIds.length && newIds.length > oldIds.length) {
        for (var j = prefix; j < rows.length; j++) {
          tbody.insertAdjacentHTML('beforeend', caseTimelineRowHtml(rows[j]));
        }
        return;
      }

      tbody.innerHTML = rows.map(caseTimelineRowHtml).join('');
    }

    function loadCases() {
      var query = new URLSearchParams();
      if (q('request-id').value.trim()) query.set('request_id', q('request-id').value.trim());
      if (q('subject-filter').value.trim()) query.set('subject', q('subject-filter').value.trim());
      if (q('event-type').value) query.set('event_type', q('event-type').value);
      if (q('outcome-filter').value) query.set('outcome', q('outcome-filter').value);
      if (q('limit').value) query.set('limit', q('limit').value);
      api('/observability/cases?' + query.toString()).then(renderCasesTable).catch(console.error);
    }

    function showCaseTimelinePanel(show) {
      var el = q('case-timeline-panel');
      if (!el) return;
      if (show) el.removeAttribute('hidden');
      else el.setAttribute('hidden', 'hidden');
    }

    function loadCaseTimeline(requestId) {
      if (!requestId) return;
      api('/observability/flows?request_id=' + encodeURIComponent(requestId) + '&include_nats_payload=1').then(function(payload) {
        renderCaseTimeline(payload, requestId);
      }).catch(console.error);
    }

    function tickMetrics() {
      api('/observability/metrics').then(function(metrics) {
        renderMetrics(metrics);
        appendChartPoint(metrics);
      }).catch(console.error);
    }

    function loadNatsState() {
      api('/observability/nats').then(renderNatsState).catch(console.error);
    }

    function tick() {
      tickMetrics();
      loadNatsState();
      loadCases();
      if (selectedRequestId) loadCaseTimeline(selectedRequestId);
    }

    function refreshCases() {
      loadCases();
      if (selectedRequestId) loadCaseTimeline(selectedRequestId);
    }

    q('refresh-cases').addEventListener('click', refreshCases);
    q('stream-reconstruct-toggle').addEventListener('click', function() {
      var body = document.querySelector('.stream-reconstruct-body');
      if (!body) return;
      var collapsed = body.style.display === 'none';
      body.style.display = collapsed ? '' : 'none';
      this.textContent = collapsed ? 'Collapse' : 'Expand';
    });
    q('case-events-table').addEventListener('click', function(event) {
      var btn = event.target.closest('.payload-expand-btn');
      if (!btn) return;
      var wrap = btn.closest('.payload-wrap');
      if (!wrap) return;
      var head = wrap.querySelector('.payload-head');
      var tail = wrap.querySelector('.payload-tail');
      var full = wrap.querySelector('.payload-full');
      if (!full) return;
      if (head) head.style.display = 'none';
      if (tail) tail.style.display = 'none';
      full.style.display = 'block';
      btn.style.display = 'none';
    });
    q('cases-table').addEventListener('click', function(event) {
      var row = event.target.closest('tr[data-request-id]');
      if (!row) return;
      selectedRequestId = row.getAttribute('data-request-id');
      showCaseTimelinePanel(true);
      loadCaseTimeline(selectedRequestId);
    });

    chartSvg = q('load-chart');
    loadNatsState();
    loadCases();
    tickMetrics();
    setInterval(tick, 3000);
  })();
